# --- Database ---
DATABASE_URL="postgresql://USER:PASS@HOST:PORT/dbname"

# --- Auth ---
JWT_SECRET="change-me-to-a-long-random-string"

# Owner account seeded on first boot.
OWNER_EMAIL="owner@example.com"
OWNER_PASSWORD="change-me"

# --- n8n ingest webhook (optional path; the proxy below covers most cases) ---
# Shared secret n8n sends in the x-ingest-secret header on POST /api/messages/ingest.
INGEST_SECRET="another-long-random-string"

# --- Proxy gate ---
# The proxy is reached at POST /api/proxy/<PROXY_TOKEN>. Put a long random
# string here and only configure GHL with that URL. Anything that doesn't
# match returns 404.
PROXY_TOKEN="yet-another-long-random-string"
# Where the proxy forwards the body when balance is available. This is the
# n8n webhook URL you were calling directly from GHL before.
PROXY_TARGET_URL="https://primary-production-xxxx.up.railway.app/webhook/xxxxx"

# --- Recharge webhook ---
# Header `x-recharge-secret` value. POST { amount, source?, reference? } to
# /api/proxy/recharge increments availableBalance. `reference` is treated
# as an idempotency key, so retries from your payment provider are safe.
RECHARGE_SECRET="recharge-shared-secret"

# --- Optional ---
PORT=8080
COST_PER_MESSAGE=0.01

# Per-minute rate for VAPI calls ingested at /api/calls/ingest. Cost is
# computed as durationSeconds / 60 * CALL_RATE_PER_MINUTE and snapshotted
# on the row, so changing this later doesn't rewrite historical totals.
CALL_RATE_PER_MINUTE=0.10
